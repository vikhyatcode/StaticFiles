                                "personal",
                                "team",
                                "groupChat"
                            ],
                            "supportsFiles": false,
                            "supportsCalling": false,
                            "supportsVideo": false
                        }
                    ],
                    "permissions": [
                        "identity",
                        "messageTeamMembers"
                    ],
                    "validDomains": [
                        "*.botframework.com",
                        "login.microsoftonline.com",
                        "*.*.botframework.com"
                    ],
                    "webApplicationInfo": {
                        "id": "{$.webApplicationInfo.id}",
                        "resource": "{$.webApplicationInfo.resource}"
                    },
                }
            }
        ]
    }
